      <div class="products-grid" id="home-products-grid"></div>
    </div>

    <!-- Footer -->
    <footer style="background:var(--gray-900);color:#fff;padding:40px 16px;margin-top:40px;">
      <div style="max-width:1100px;margin:auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:32px;">
        <div>
          <div style="font-family:'Baloo 2';font-size:1.4rem;font-weight:800;color:var(--green-light);margin-bottom:10px;">🛒 ValueKart</div>
          <p style="font-size:0.85rem;color:rgba(255,255,255,0.6);line-height:1.6;">Shop Smart. Save More. India's trusted budget shopping destination with ₹100 cashback on every order.</p>
        </div>
