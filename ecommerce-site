<script>
// ======================== DATA LAYER ========================
const ADMIN_EMAIL = 'the.salman9663@gmail.com';
const ADMIN_PASS_HASH = btoa('Salman@6119'); // simple obfuscation
const WA_NUMBER = '919645559663';

function getData(key, def) {
  try { const d = localStorage.getItem(key); return d ? JSON.parse(d) : def; } catch { return def; }
}
function setData(key, val) { localStorage.setItem(key, JSON.stringify(val)); }

function getProducts() { return getData('vk_products', []); }
function getOrders() { return getData('vk_orders', []); }
function getCart() { return getData('vk_cart', []); }
function setProducts(p) { setData('vk_products', p); }
function setOrders(o) { setData('vk_orders', o); }
function setCart(c) { setData('vk_cart', c); renderCartCount(); }

// Seed default products if none
function seedProducts() {
  if (getProducts().length > 0) return;
  const defaults = [
    { id: 'p1', name: 'Smart Analog Watch', price: 799, category: 'watches', colour: 'Black', sizes: ['Free Size'], desc: 'Premium analog watch with stylish design. Water resistant and durable.', image: '', commission: 200, stock: 30, emoji: '⌚' },
    { id: 'p2', name: 'Running Sports Shoes', price: 1299, category: 'shoes', colour: 'White/Blue', sizes: ['6','7','8','9','10'], desc: 'Comfortable running shoes with EVA sole and mesh upper for breathability.', image: '', commission: 350, stock: 25, emoji: '👟' },
    { id: 'p3', name: 'Wireless Earbuds', price: 599, category: 'gadgets', colour: 'White', sizes: ['Free Size'], desc: 'True wireless earbuds with 20hr battery life and deep bass.', image: '', commission: 150, stock: 40, emoji: '🎧' },
    { id: 'p4', name: 'Casual Cotton T-Shirt', price: 399, category: 'clothes', colour: 'Blue', sizes: ['S','M','L','XL','XXL'], desc: 'Premium cotton round neck t-shirt, breathable and comfortable.', image: '', commission: 100, stock: 60, emoji: '👕' },
    { id: 'p5', name: 'Digital Fitness Watch', price: 1099, category: 'watches', colour: 'Black/Red', sizes: ['Free Size'], desc: 'Fitness tracker with heart rate monitor, steps counter and sleep tracking.', image: '', commission: 300, stock: 20, emoji: '⌚' },
    { id: 'p6', name: 'Bluetooth Speaker', price: 899, category: 'gadgets', colour: 'Black', sizes: ['Free Size'], desc: 'Portable waterproof Bluetooth speaker with 360° surround sound.', image: '', commission: 250, stock: 35, emoji: '🔊' },
  ];
  setProducts(defaults);
}
seedProducts();

// ======================== NAVIGATION ========================
let currentPage = 'home';
let prevPage = 'home';
let selectedPayment = 'upi';
let currentProductId = null;
let editingSizes = [];

function navigate(page, data) {
  prevPage = currentPage;
  currentPage = page;
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const pg = document.getElementById('page-' + page);
  if (pg) pg.classList.add('active');
  window.scrollTo(0, 0);
  // Update nav active
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  if (page === 'home') document.getElementById('nav-home')?.classList.add('active');
  if (page === 'products') document.getElementById('nav-products')?.classList.add('active');

  if (page === 'home') renderHomeProducts();
  if (page === 'products') renderAllProducts();
  if (page === 'detail' && data) renderProductDetail(data);
  if (page === 'checkout') renderCheckout();
  if (page === 'confirmation' && data) renderConfirmation(data);
}

function goBack() { navigate(prevPage); }

function showSite() {
  document.getElementById('main-site').classList.remove('hidden');
  document.getElementById('admin-panel').classList.add('hidden');
  document.getElementById('admin-access-bar').classList.remove('hidden');
}
function showAdmin() {
  document.getElementById('main-site').classList.add('hidden');
  document.getElementById('admin-panel').classList.remove('hidden');
  document.getElementById('admin-access-bar').classList.add('hidden');
}

// ======================== TOAST ========================
function toast(msg, duration = 2800) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), duration);
}

// ======================== CART ========================
function renderCartCount() {
  const cart = getCart();
  const count = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('cart-count').textContent = count;
}
renderCartCount();

function addToCart(productId, size) {
  const products = getProducts();
  const product = products.find(p => p.id === productId);
  if (!product) return;
  const cart = getCart();
  const key = productId + '-' + (size || 'default');
  const existing = cart.find(i => i.key === key);
  if (existing) { existing.qty++; } else { cart.push({ key, productId, size: size || '', name: product.name, price: product.price, qty: 1, emoji: product.emoji || '📦' }); }
  setCart(cart);
  toast('✅ Added to cart!');
}

// ======================== RENDER PRODUCTS ========================
function productCardHTML(p, mini = false) {
  const imgContent = p.image
    ? `<img src="${p.image}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;">`
    : `<div style="font-size:3.5rem;">${p.emoji || getCategoryEmoji(p.category)}</div>`;
  const sizeSelect = p.sizes && p.sizes.length > 1
    ? `<select onchange="this.dataset.size=this.value" style="width:100%;padding:6px 10px;border:2px solid var(--gray-200);border-radius:8px;font-family:'Nunito';font-size:0.82rem;margin-bottom:6px;" id="size-sel-${p.id}"><option value="">Select Size</option>${p.sizes.map(s => `<option value="${s}">${s}</option>`).join('')}</select>` : '';
  return `
    <div class="product-card" onclick="navigate('detail','${p.id}')">
      <div class="product-img-placeholder" style="aspect-ratio:1;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--gray-100);">${imgContent}</div>
      <div class="product-info">
        <div class="badge badge-green" style="margin-bottom:8px;">🎁 ₹100 Cashback</div>
        <div class="product-name">${p.name}</div>
        <div class="product-price">₹${Number(p.price).toLocaleString('en-IN')}</div>
        ${sizeSelect}
        <div class="product-actions" onclick="event.stopPropagation()">
          <a href="${waOrderLink(p)}" target="_blank" class="btn btn-wa btn-sm" style="width:100%;justify-content:center;">💬 Order via WhatsApp</a>
        </div>
      </div>
    </div>`;
}

function getCategoryEmoji(cat) {
  const map = { watches: '⌚', shoes: '👟', gadgets: '📱', clothes: '👕', other: '📦' };
  return map[cat] || '📦';
}

function waOrderLink(p) {
  const msg = encodeURIComponent(`Hi! I want to order:\n\n🛍️ *${p.name}*\n💰 Price: ₹${p.price}\n🎁 + ₹100 Cashback after delivery\n\nPlease confirm availability.`);
  return `https://wa.me/${WA_NUMBER}?text=${msg}`;
}

function quickAddCart(productId) {
  const sizeEl = document.getElementById('size-sel-' + productId);
  const size = sizeEl ? sizeEl.value : '';
  addToCart(productId, size);
}

function renderHomeProducts() {
  const products = getProducts().reverse().slice(0, 6);
  const grid = document.getElementById('home-products-grid');
  if (!grid) return;
  if (products.length === 0) {
    grid.innerHTML = '<div class="empty-state"><div class="icon">📦</div><p>No products yet. Add products from the admin panel.</p></div>';
    return;
  }
  grid.innerHTML = products.map(p => productCardHTML(p)).join('');
}

function renderAllProducts(filter = 'all') {
  const products = filter === 'all' ? getProducts() : getProducts().filter(p => p.category === filter);
  const grid = document.getElementById('all-products-grid');
  if (!grid) return;
  if (products.length === 0) {
    grid.innerHTML = '<div class="empty-state"><div class="icon">📦</div><p>No products in this category.</p></div>';
    return;
  }
  grid.innerHTML = products.map(p => productCardHTML(p)).join('');
  renderFilterBar();
}

function renderFilterBar() {
  const products = getProducts();
  const cats = [...new Set(products.map(p => p.category))];
  const catNames = { watches: '⌚ Watches', shoes: '👟 Shoes', gadgets: '📱 Gadgets', clothes: '👕 Clothes', other: '📦 Other' };
  const bar = document.getElementById('filter-bar');
  if (!bar) return;
  bar.innerHTML = `<button class="filter-btn active" onclick="filterProducts('all',this)">All</button>` +
    cats.map(c => `<button class="filter-btn" onclick="filterProducts('${c}',this)">${catNames[c] || c}</button>`).join('');
}

function filterProducts(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderAllProducts(cat);
}

// ======================== PRODUCT DETAIL ========================
function renderProductDetail(productId) {
  currentProductId = productId;
  const p = getProducts().find(pr => pr.id === productId);
  if (!p) { navigate('products'); return; }
  const imgContent = p.image
    ? `<img src="${p.image}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;">`
    : `<div style="font-size:7rem;">${p.emoji || getCategoryEmoji(p.category)}</div>`;
  const sizeBtns = p.sizes && p.sizes.length > 0
    ? `<div><label style="font-weight:700;font-size:0.9rem;margin-bottom:8px;display:block;">Select Size</label><div class="size-options" id="detail-sizes">${p.sizes.map(s => `<button class="size-btn" onclick="selectSize(this,'${s}')">${s}</button>`).join('')}</div></div>` : '';
  document.getElementById('product-detail-content').innerHTML = `
    <div class="product-detail-img">${imgContent}</div>
    <div class="product-detail-info">
      <div>
        <div class="badge badge-green" style="margin-bottom:10px;">🎁 ₹100 Cashback After Delivery</div>
        <h1 style="font-size:1.6rem;margin-bottom:8px;">${p.name}</h1>
        <div class="product-detail-price">₹${Number(p.price).toLocaleString('en-IN')}</div>
      </div>
      ${sizeBtns}
      <div class="cashback-box">
        <h4>🎁 ₹100 Cashback Offer</h4>
        <p>Cashback will be credited to your UPI within 7 days after delivery. No minimum order!</p>
      </div>
      ${p.desc ? `<p style="color:var(--gray-500);font-size:0.9rem;line-height:1.6;">${p.desc}</p>` : ''}
      ${p.colour ? `<p style="font-size:0.88rem;"><strong>Colour:</strong> ${p.colour}</p>` : ''}
      <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px;">
        <a href="${waOrderLink(p)}" target="_blank" class="btn btn-wa btn-lg" style="justify-content:center;">💬 Order via WhatsApp</a>
      </div>
    </div>`;
}

let detailSelectedSize = '';
function selectSize(btn, size) {
  document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  detailSelectedSize = size;
}
function detailAddCart() {
  if (currentProductId) { addToCart(currentProductId, detailSelectedSize); navigate('checkout'); }
}

// ======================== CHECKOUT ========================
function renderCheckout() {
  const cart = getCart();
  const items = document.getElementById('checkout-items');
  if (!items) return;
  if (cart.length === 0) {
    items.innerHTML = '<div style="text-align:center;padding:20px;color:var(--gray-500);">Your cart is empty. <span style="cursor:pointer;color:var(--green);font-weight:700;" onclick="navigate(\'products\')">Shop now →</span></div>';
    document.getElementById('checkout-total').textContent = '₹0';
    return;
  }
  let total = 0;
  items.innerHTML = cart.map(i => {
    total += i.price * i.qty;
    return `<div class="order-item-row">
      <span>${i.emoji || '📦'} ${i.name}${i.size ? ' ('+i.size+')' : ''} × ${i.qty}</span>
      <span style="font-weight:700;">₹${(i.price * i.qty).toLocaleString('en-IN')}</span>
    </div>`;
  }).join('');
  document.getElementById('checkout-total').textContent = '₹' + total.toLocaleString('en-IN');
}

function selectPayment(method) {
  selectedPayment = method;
  document.getElementById('pay-upi').classList.toggle('selected', method === 'upi');
  document.getElementById('pay-cod').classList.toggle('selected', method === 'cod');
}

function placeOrder() {
  const name = document.getElementById('ch-name').value.trim();
  const phone = document.getElementById('ch-phone').value.trim();
  const address = document.getElementById('ch-address').value.trim();
  const cart = getCart();
  if (!name || !phone || !address) { toast('⚠️ Please fill all delivery details.'); return; }
  if (cart.length === 0) { toast('⚠️ Your cart is empty!'); return; }

  if (selectedPayment === 'upi') {
    initiateRazorpay(name, phone, address, cart);
  } else {
    createOrder(name, phone, address, cart, 'COD');
  }
}

function getTotalAmount(cart) {
  return cart.reduce((s, i) => s + i.price * i.qty, 0);
}

function initiateRazorpay(name, phone, address, cart) {
  const total = getTotalAmount(cart);
  // Check if Razorpay is available, otherwise simulate
  if (typeof Razorpay === 'undefined') {
    // Simulate UPI payment success for demo
    toast('💳 Processing UPI payment...');
    setTimeout(() => { createOrder(name, phone, address, cart, 'UPI - Paid'); }, 1500);
    return;
  }
  const options = {
    key: 'rzp_test_YOUR_KEY_HERE', // Replace with actual Razorpay key
    amount: total * 100,
    currency: 'INR',
    name: 'Value Kart',
    description: 'Order Payment',
    prefill: { name, contact: phone },
    theme: { color: '#16a34a' },
    handler: function() { createOrder(name, phone, address, cart, 'UPI - Paid'); }
  };
  const rzp = new Razorpay(options);
  rzp.open();
}

function createOrder(name, phone, address, cart, paymentMethod) {
  const orderId = 'VK' + Date.now();
  const total = getTotalAmount(cart);
  const order = {
    id: orderId,
    name, phone, address,
    items: [...cart],
    total,
    paymentMethod,
    status: 'Placed',
    cashbackStatus: 'Pending',
    deliveredDate: null,
    cashbackDate: null,
    createdAt: new Date().toISOString()
  };
  const orders = getOrders();
  orders.push(order);
  setOrders(orders);
  setCart([]);
  navigate('confirmation', order);
}

// ======================== CONFIRMATION ========================
function renderConfirmation(order) {
  const items = order.items || [];
  const summary = items.map(i => `${i.name} × ${i.qty}`).join(', ');
  const msg = encodeURIComponent(`✅ *Order Confirmed - Value Kart*\n\nOrder ID: ${order.id}\nCustomer: ${order.name}\nPhone: ${order.phone}\nAddress: ${order.address}\n\nItems: ${summary}\nTotal: ₹${order.total}\nPayment: ${order.paymentMethod}\n\n🎁 ₹100 cashback will be credited within 7 days after delivery!\n\nThank you for shopping with Value Kart! 🛒`);
  const btn = document.getElementById('wa-confirm-btn');
  if (btn) btn.href = `https://wa.me/${WA_NUMBER}?text=${msg}`;
}

// ======================== ADMIN AUTH ========================
function adminLogin() {
  const email = document.getElementById('admin-email').value.trim();
  const pass = document.getElementById('admin-pass').value;
  if (email === ADMIN_EMAIL && btoa(pass) === ADMIN_PASS_HASH) {
    sessionStorage.setItem('vk_admin', '1');
    document.getElementById('admin-login').classList.add('hidden');
    document.getElementById('admin-dashboard').classList.remove('hidden');
    showAdminSection('dashboard');
    toast('✅ Welcome back, Admin!');
  } else {
    toast('❌ Invalid credentials. Please try again.');
  }
}

function adminLogout() {
  sessionStorage.removeItem('vk_admin');
  document.getElementById('admin-dashboard').classList.add('hidden');
  document.getElementById('admin-login').classList.remove('hidden');
  document.getElementById('admin-email').value = '';
  document.getElementById('admin-pass').value = '';
}

// ======================== ADMIN NAVIGATION ========================
function showAdminSection(section) {
  document.querySelectorAll('.admin-section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.admin-nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('sec-' + section)?.classList.add('active');
  document.getElementById('anav-' + section)?.classList.add('active');
  const titles = { dashboard: 'Dashboard', 'add-product': 'Add Product', products: 'Products', orders: 'Orders', cashback: 'Cashback Management' };
  document.getElementById('admin-section-title').textContent = titles[section] || section;
  closeSidebar();
  if (section === 'dashboard') renderAdminDashboard();
  if (section === 'products') renderAdminProducts();
  if (section === 'orders') renderAdminOrders();
  if (section === 'cashback') renderCashbackTable();
}

function toggleSidebar() {
  const sb = document.getElementById('admin-sidebar');
  const ov = document.getElementById('admin-overlay');
  sb.classList.toggle('open');
  ov.classList.toggle('show');
}
function closeSidebar() {
  document.getElementById('admin-sidebar')?.classList.remove('open');
  document.getElementById('admin-overlay')?.classList.remove('show');
}

// ======================== ADMIN DASHBOARD ========================
function renderAdminDashboard() {
  const products = getProducts();
  const orders = getOrders();
  const revenue = orders.reduce((s, o) => s + (o.total || 0), 0);
  const pending = orders.filter(o => o.cashbackStatus === 'Pending').length;
  document.getElementById('stat-cards').innerHTML = `
    <div class="stat-card"><div class="stat-icon">📦</div><div class="stat-val">${products.length}</div><div class="stat-label">Total Products</div></div>
    <div class="stat-card"><div class="stat-icon">🛒</div><div class="stat-val">${orders.length}</div><div class="stat-label">Total Orders</div></div>
    <div class="stat-card"><div class="stat-icon">💰</div><div class="stat-val">₹${revenue.toLocaleString('en-IN')}</div><div class="stat-label">Total Revenue</div></div>
    <div class="stat-card"><div class="stat-icon">🎁</div><div class="stat-val">${pending}</div><div class="stat-label">Cashback Pending</div></div>`;
  const recent = orders.slice(-5).reverse();
  const rt = document.getElementById('recent-orders-table');
  if (recent.length === 0) { rt.innerHTML = '<div class="empty-state"><div class="icon">🛒</div><p>No orders yet.</p></div>'; return; }
  rt.innerHTML = `<table><thead><tr><th>Order ID</th><th>Customer</th><th>Amount</th><th>Payment</th><th>Status</th></tr></thead><tbody>${
    recent.map(o => `<tr><td style="font-family:monospace;font-size:0.82rem;">${o.id}</td><td>${o.name}</td><td style="font-weight:700;color:var(--green-dark);">₹${o.total?.toLocaleString('en-IN')}</td><td><span class="badge ${o.paymentMethod?.includes('UPI') ? 'badge-green' : 'badge-orange'}">${o.paymentMethod}</span></td><td><span class="badge badge-yellow">${o.status}</span></td></tr>`).join('')
  }</tbody></table>`;
}

// ======================== ADMIN PRODUCT MANAGEMENT ========================
let productSizes = [];

function addSize() {
  const input = document.getElementById('p-size-input');
  const val = input.value.trim().replace(/,/g, '');
  if (!val) return;
  val.split(',').forEach(v => { v = v.trim(); if (v && !productSizes.includes(v)) productSizes.push(v); });
  input.value = '';
  renderSizeTags();
}

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('p-size-input')?.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ',') { e.preventDefault(); addSize(); }
  });
});

function renderSizeTags() {
  document.getElementById('sizes-display').innerHTML = productSizes.map((s, i) =>
    `<span class="tag">${s} <button onclick="removeSize(${i})">×</button></span>`).join('');
}

function removeSize(i) { productSizes.splice(i, 1); renderSizeTags(); }

function previewImg(input) {
  const file = input.files[0];
  if (!file) return;
  if (file.size > 2 * 1024 * 1024) { toast('⚠️ Image too large. Max 2MB.'); return; }
  const reader = new FileReader();
  reader.onload = e => {
    const preview = document.getElementById('img-preview');
    preview.src = e.target.result;
    preview.classList.remove('hidden');
  };
  reader.readAsDataURL(file);
}

function saveProduct() {
  const name = document.getElementById('p-name').value.trim();
  const price = parseFloat(document.getElementById('p-price').value);
  const category = document.getElementById('p-category').value;
  const colour = document.getElementById('p-colour').value.trim();
  const commission = parseFloat(document.getElementById('p-commission').value) || 0;
  const stock = parseInt(document.getElementById('p-stock').value) || 50;
  const desc = document.getElementById('p-desc').value.trim();
  const imgEl = document.getElementById('img-preview');
  const image = imgEl.classList.contains('hidden') ? '' : imgEl.src;
  if (!name || !price) { toast('⚠️ Product name and price are required.'); return; }
  const product = {
    id: 'p' + Date.now(),
    name, price, category, colour, commission, stock, desc,
    sizes: [...productSizes],
    image,
    emoji: getCategoryEmoji(category),
    createdAt: new Date().toISOString()
  };
  const products = getProducts();
  products.push(product);
  setProducts(products);
  clearProductForm();
  toast('✅ Product saved and synced to store!');
  renderHomeProducts();
  showAdminSection('products');
}

function clearProductForm() {
  ['p-name','p-price','p-colour','p-commission','p-desc'].forEach(id => { const el = document.getElementById(id); if(el) el.value = ''; });
  document.getElementById('p-stock').value = '50';
  document.getElementById('p-category').value = 'watches';
  const preview = document.getElementById('img-preview');
  if (preview) { preview.src = ''; preview.classList.add('hidden'); }
  document.getElementById('p-image').value = '';
  productSizes = [];
  renderSizeTags();
}

function renderAdminProducts(filter = '') {
  let products = getProducts();
  if (filter) products = products.filter(p => p.name.toLowerCase().includes(filter.toLowerCase()));
  const container = document.getElementById('admin-products-table');
  if (!container) return;
  if (products.length === 0) { container.innerHTML = '<div class="empty-state"><div class="icon">📦</div><p>No products yet.</p></div>'; return; }
  container.innerHTML = `<table><thead><tr><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th>Actions</th></tr></thead><tbody>${
    products.map(p => `<tr>
      <td><div style="display:flex;align-items:center;gap:10px;">${p.image ? `<img src="${p.image}" style="width:36px;height:36px;border-radius:6px;object-fit:cover;">` : `<span style="font-size:1.4rem;">${p.emoji || '📦'}</span>`}<strong>${p.name}</strong></div></td>
      <td><span class="badge badge-green">${p.category}</span></td>
      <td style="font-weight:800;color:var(--green-dark);">₹${Number(p.price).toLocaleString('en-IN')}</td>
      <td>${p.stock || '-'}</td>
      <td><div style="display:flex;gap:6px;flex-wrap:wrap;">
        <button class="btn btn-outline btn-sm" onclick="openEditModal('${p.id}')">✏️ Edit</button>
        <button class="btn btn-sm" style="background:var(--red);color:#fff;" onclick="deleteProduct('${p.id}')">🗑️ Delete</button>
      </div></td>
    </tr>`).join('')
  }</tbody></table>`;
}

function searchAdminProducts(val) { renderAdminProducts(val); }

function deleteProduct(id) {
  if (!confirm('Delete this product? This cannot be undone.')) return;
  setProducts(getProducts().filter(p => p.id !== id));
  renderAdminProducts();
  toast('🗑️ Product deleted.');
}

function openEditModal(id) {
  const p = getProducts().find(pr => pr.id === id);
  if (!p) return;
  document.getElementById('edit-product-id').value = p.id;
  document.getElementById('edit-name').value = p.name;
  document.getElementById('edit-price').value = p.price;
  document.getElementById('edit-category').value = p.category;
  document.getElementById('edit-colour').value = p.colour || '';
  document.getElementById('edit-stock').value = p.stock || '';
  document.getElementById('edit-desc').value = p.desc || '';
  document.getElementById('edit-modal').classList.remove('hidden');
}
function closeEditModal() { document.getElementById('edit-modal').classList.add('hidden'); }

function updateProduct() {
  const id = document.getElementById('edit-product-id').value;
  const products = getProducts();
  const i = products.findIndex(p => p.id === id);
  if (i === -1) return;
  products[i] = { ...products[i],
    name: document.getElementById('edit-name').value.trim(),
    price: parseFloat(document.getElementById('edit-price').value),
    category: document.getElementById('edit-category').value,
    colour: document.getElementById('edit-colour').value.trim(),
    stock: parseInt(document.getElementById('edit-stock').value) || 0,
    desc: document.getElementById('edit-desc').value.trim(),
    emoji: getCategoryEmoji(document.getElementById('edit-category').value)
  };
  setProducts(products);
  closeEditModal();
  renderAdminProducts();
  toast('✅ Product updated!');
}

// ======================== ADMIN ORDERS ========================
function renderAdminOrders() {
  const orders = getOrders().reverse();
  const container = document.getElementById('admin-orders-table');
  if (!container) return;
  if (orders.length === 0) { container.innerHTML = '<div class="empty-state"><div class="icon">🛒</div><p>No orders received yet.</p></div>'; return; }
  container.innerHTML = `<div style="overflow-x:auto;"><table><thead><tr><th>Order ID</th><th>Customer</th><th>Address</th><th>Amount</th><th>Payment</th><th>Status</th><th>Action</th></tr></thead><tbody>${
    orders.map(o => `<tr>
      <td style="font-family:monospace;font-size:0.8rem;">${o.id}</td>
      <td><strong>${o.name}</strong><br><span style="font-size:0.8rem;color:var(--gray-500);">${o.phone}</span></td>
      <td style="font-size:0.82rem;max-width:180px;word-break:break-word;">${o.address}</td>
      <td style="font-weight:800;color:var(--green-dark);">₹${o.total?.toLocaleString('en-IN')}</td>
      <td><span class="badge ${o.paymentMethod?.includes('UPI') ? 'badge-green' : 'badge-orange'}">${o.paymentMethod}</span></td>
      <td><span class="badge ${o.status === 'Delivered' ? 'badge-green' : 'badge-yellow'}">${o.status}</span></td>
      <td>
        ${o.status !== 'Delivered' ? `<button class="btn btn-green btn-sm" onclick="markDelivered('${o.id}')">✅ Mark Delivered</button>` : '<span style="color:var(--green);font-weight:700;font-size:0.85rem;">Delivered ✓</span>'}
      </td>
    </tr>`).join('')
  }</tbody></table></div>`;
}

function markDelivered(orderId) {
  const orders = getOrders();
  const o = orders.find(o => o.id === orderId);
  if (!o) return;
  o.status = 'Delivered';
  o.deliveredDate = new Date().toISOString();
  o.cashbackStatus = 'Processing';
  setOrders(orders);
  renderAdminOrders();
  renderCashbackTable();
  toast('✅ Order marked as delivered!');
}

// ======================== CASHBACK ========================
function renderCashbackTable() {
  const orders = getOrders().filter(o => o.status === 'Delivered' || o.cashbackStatus !== 'Pending').reverse();
  const container = document.getElementById('cashback-table');
  if (!container) return;
  if (orders.length === 0) { container.innerHTML = '<div class="empty-state"><div class="icon">💰</div><p>No delivered orders yet.</p></div>'; return; }
  container.innerHTML = `<div style="overflow-x:auto;"><table><thead><tr><th>Order ID</th><th>Customer</th><th>Phone</th><th>Amount</th><th>Delivered On</th><th>Cashback Status</th><th>Action</th></tr></thead><tbody>${
    orders.map(o => {
      const delivDate = o.deliveredDate ? new Date(o.deliveredDate) : null;
      const now = new Date();
      const daysDiff = delivDate ? Math.floor((now - delivDate) / (1000 * 60 * 60 * 24)) : 0;
      const eligible = daysDiff >= 7 && o.cashbackStatus !== 'Given';
      return `<tr>
        <td style="font-family:monospace;font-size:0.8rem;">${o.id}</td>
        <td><strong>${o.name}</strong></td>
        <td style="font-size:0.85rem;">${o.phone}</td>
        <td style="font-weight:800;color:var(--green-dark);">₹${o.total?.toLocaleString('en-IN')}</td>
        <td style="font-size:0.82rem;">${delivDate ? delivDate.toLocaleDateString('en-IN') : '-'}<br><span style="font-size:0.75rem;color:var(--gray-500);">${delivDate ? daysDiff + ' days ago' : ''}</span></td>
        <td><span class="badge ${o.cashbackStatus === 'Given' ? 'badge-green' : eligible ? 'badge-orange' : 'badge-yellow'}">${o.cashbackStatus === 'Given' ? '✅ Given' : eligible ? '🟡 Eligible' : '⏳ ' + o.cashbackStatus}</span></td>
        <td>${o.cashbackStatus === 'Given' ? '<span style="color:var(--green);font-weight:700;font-size:0.85rem;">Completed ✓</span>' : eligible ? `<button class="btn btn-green btn-sm" onclick="markCashback('${o.id}')">💰 Mark Given</button>` : `<span style="font-size:0.8rem;color:var(--gray-500);">${delivDate ? (7 - daysDiff) + ' days left' : 'Pending delivery'}</span>`}
        </td>
      </tr>`;
    }).join('')
  }</tbody></table></div>`;
}

function markCashback(orderId) {
  const orders = getOrders();
  const o = orders.find(o => o.id === orderId);
  if (!o) return;
  o.cashbackStatus = 'Given';
  o.cashbackDate = new Date().toISOString();
  setOrders(orders);
  renderCashbackTable();
  toast('💰 ₹100 cashback marked as given!');
}

// ======================== ADMIN ACCESS BAR ========================
function openAdminPanel() {
  showAdmin();
  if (sessionStorage.getItem('vk_admin')) {
    document.getElementById('admin-login').classList.add('hidden');
    document.getElementById('admin-dashboard').classList.remove('hidden');
    showAdminSection('dashboard');
  }
}

// Password visibility toggle removed for security - credentials should not be displayed

// ======================== ADMIN ROUTE ========================
function checkAdminRoute() {
  if (window.location.hash === '#admin') {
    showAdmin();
    if (sessionStorage.getItem('vk_admin')) {
      document.getElementById('admin-login').classList.add('hidden');
      document.getElementById('admin-dashboard').classList.remove('hidden');
      showAdminSection('dashboard');
    }
  }
}

// ======================== INIT ========================
checkAdminRoute();
renderHomeProducts();
renderCartCount();

// URL hash routing for admin
window.addEventListener('hashchange', checkAdminRoute);
</script>

